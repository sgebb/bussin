@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Bussin.Services
@inherits LayoutComponentBase
@implements IDisposable
@inject IPreferencesService PreferencesService
@inject NavigationStateService NavState
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationService NotificationService
@inject BackgroundSearchService BackgroundSearch
@inject NavigationManager Navigation
@inject ExplorerDialogService DialogService
@inject PeekService PeekService
@inject MessageListState MessageListState
@inject IJSRuntime JSRuntime
@inject EntitySelectionState SelectionState
@inject HttpClient Http

<CascadingValue Value="@_isInitialized" Name="LayoutInitialized">
    @if (NavState.RunWithoutLogin)
    {
        @if (_isInitialized)
        {
            @RenderLayoutShell()
        }
        else
        {
            <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
    }
    else
    {
        <AuthorizeView>
            <Authorized>
                @if (_isInitialized)
                {
                    @RenderLayoutShell()
                }
                else
                {
                    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
            </Authorized>
            <Authorizing>
                <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Authenticating...</span>
                    </div>
                </div>
            </Authorizing>
            <NotAuthorized>
                @Body
            </NotAuthorized>
        </AuthorizeView>
    }
</CascadingValue>

@code {
    private bool _isDarkMode;
    private bool _isInitialized;
    private bool _isMobileMenuOpen = false;

    private void ToggleMobileMenu()
    {
        _isMobileMenuOpen = !_isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        _isMobileMenuOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to auth state changes to handle post-login initialization
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        NavState.OnDeleteModalChange += OnDeleteModalChange;
        NavState.OnSupportModalChange += OnSupportModalChange;
        NavState.OnChange += OnNavStateChange;
        NavState.OnAddConnectionStringModalChange += OnAddConnectionStringModalChange;
        DialogService.OnChange += OnDialogStateChange;
        
        await InitializeIfAuthenticatedAsync();

        try
        {
            buildInfo = await Http.GetFromJsonAsync<BuildInfoModel>("buildinfo.json");
        }
        catch
        {
            buildInfo = new BuildInfoModel
            {
                CommitHash = "dev",
                CommitShort = "dev",
                BuildTime = DateTime.UtcNow.ToString("o"),
                Branch = "local",
                Repository = "local-development",
                VerifyUrl = "#"
            };
        }
    }

    private void OnNavStateChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnDeleteModalChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnSupportModalChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnAddConnectionStringModalChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnDialogStateChange()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SaveManualNamespace(NamespaceConnection ns)
    {
        await NavState.AddNamespaceConnectionAsync(ns);
        NavState.HideAddConnectionStringModal();
        NotificationService.NotifySuccess("Manual connection saved successfully.");
    }

    private async Task ConfirmDeleteFolder()
    {
        await NavState.ConfirmDeleteFolderAsync();
    }

    private void HandleViewSearchResults(SearchOperation operation)
    {
        BackgroundSearch.RequestViewResults(operation);
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        // Re-initialize when auth state changes (e.g., after login redirect)
        await InitializeIfAuthenticatedAsync();
        CloseMobileMenu();
        await InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        CloseMobileMenu();
        InvokeAsync(StateHasChanged);
    }

    private async Task InitializeIfAuthenticatedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var prefs = await PreferencesService.LoadPreferencesAsync();
        _isDarkMode = prefs.DarkMode;
        
        await NavState.InitializeAsync();
        _isInitialized = true;
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        
        var prefs = await PreferencesService.LoadPreferencesAsync();
        prefs.DarkMode = _isDarkMode;
        await PreferencesService.SavePreferencesAsync(prefs);
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        NavState.OnDeleteModalChange -= OnDeleteModalChange;
        NavState.OnSupportModalChange -= OnSupportModalChange;
        NavState.OnChange -= OnNavStateChange;
        NavState.OnAddConnectionStringModalChange -= OnAddConnectionStringModalChange;
        DialogService.OnChange -= OnDialogStateChange;
        _selfReference?.Dispose();
    }

    private RenderFragment RenderLayoutShell() => __builder =>
    {
        <div class="page" data-theme="@(_isDarkMode ? "dark" : "light")">
            <!-- Mobile Top Header -->
            <div class="mobile-top-nav d-md-none">
                <button class="mobile-nav-toggle" @onclick="ToggleMobileMenu" aria-label="Toggle Navigation">
                    <i class="bi @(_isMobileMenuOpen ? "bi-x-lg" : "bi-list")"></i>
                </button>
                <a class="mobile-brand text-decoration-none" href="/" @onclick:preventDefault @onclick="@(() => Navigation.NavigateTo("/"))">
                    <img src="favicon.svg" alt="bussin logo" class="mobile-logo" />
                    <span>bussin</span>
                </a>
                <button class="mobile-theme-toggle" @onclick="ToggleDarkMode" title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
                    <i class="bi @(_isDarkMode ? "bi-brightness-high-fill" : "bi-moon-fill")"></i>
                </button>
            </div>

            <!-- Sidebar drawer overlay on mobile -->
            <div class="sidebar @(_isMobileMenuOpen ? "mobile-open" : "")">
                <NavMenu IsDarkMode="@_isDarkMode" OnToggleDarkMode="@ToggleDarkMode" />
            </div>

            <!-- Mobile Sidebar Backdrop -->
            @if (_isMobileMenuOpen)
            {
                <div class="mobile-nav-backdrop d-md-none" @onclick="CloseMobileMenu"></div>
            }

            <main @onclick="CloseMobileMenu">
                <article class="content">
                    @Body
                </article>
            </main>
        </div>

        <div data-theme="@(_isDarkMode ? "dark" : "light")">
            <NotificationsSidebar />
            <TasksSidebar OnViewSearchResults="@HandleViewSearchResults" />
        </div>

        <!-- Support Modal (rendered outside .page for proper z-index) -->
        @if (NavState.ShowSupportModal)
        {
            <div class="modal show d-block" tabindex="-1" data-theme="@(_isDarkMode ? "dark" : "light")" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.5); z-index: 9999;" @onclick="NavState.HideSupportModal">
                <div class="modal-dialog modal-dialog-centered modal-sm">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-heart-fill text-danger me-2"></i>Support bussin</h5>
                            <button type="button" class="btn-close" @onclick="NavState.HideSupportModal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-3">Enjoying bussin? Give it a star or make a Github Issue if you have a request!</p>
                            <div class="d-flex flex-column gap-2">
                                <a href="https://github.com/sgebb/bussin" target="_blank" rel="noopener" class="btn btn-github w-100">
                                    <i class="bi bi-github me-1"></i> GitHub
                                </a>
                                <a href="https://buymeacoffee.com/sgebb" target="_blank" rel="noopener" class="btn btn-bmc w-100">
                                    <i class="bi bi-cup-hot-fill me-1"></i> Buy me a coffee
                                </a>
                            </div>
                            
                            @if (buildInfo != null)
                            {
                                <div class="mt-4 pt-3 border-top text-center text-muted" style="font-size: 0.72rem; line-height: 1.4;">
                                    <div class="mb-1">Version: <code>@buildInfo.CommitShort</code></div>
                                    @if (buildInfo.BuildTime != "Unknown" && buildInfo.CommitShort != "dev")
                                    {
                                        <div class="mb-1">Built: @FormatBuildTime(buildInfo.BuildTime)</div>
                                    }
                                    @if (buildInfo.VerifyUrl != "#")
                                    {
                                        <a href="@buildInfo.VerifyUrl" target="_blank" class="text-muted text-decoration-underline" style="font-size: 0.68rem;">Verify source code</a>
                                    }
                                    else
                                    {
                                        <a href="https://github.com/sgebb/bussin" target="_blank" class="text-muted text-decoration-underline" style="font-size: 0.68rem;">GitHub Repository</a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Delete Folder Confirmation Modal (rendered outside .page for proper z-index) -->
        @if (NavState.ShowDeleteFolderModal)
        {
            <div class="modal show d-block" tabindex="-1" data-theme="@(_isDarkMode ? "dark" : "light")" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.5); z-index: 9999;" @onclick="NavState.HideDeleteFolderModal">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" @onclick:stopPropagation="true">
                        <div class="modal-header">
                            <h5 class="modal-title">Delete Folder</h5>
                            <button type="button" class="btn-close" @onclick="NavState.HideDeleteFolderModal"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete the folder <strong>@NavState.FolderNameToDelete</strong>?</p>
                            @if (NavState.FolderNamespaceCount > 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i> This folder contains <strong>@NavState.FolderNamespaceCount</strong> namespace(s). They will be moved to the default "Namespaces" folder.
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="NavState.HideDeleteFolderModal">Cancel</button>
                            <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteFolder">Delete Folder</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Add Connection String Modal (rendered outside .page for proper z-index) -->
        @if (NavState.ShowAddConnectionStringModal)
        {
            <AddConnectionStringModal IsVisible="true"
                                      IsDarkMode="@_isDarkMode"
                                      NamespaceToEdit="@NavState.EditingNamespace"
                                      OnClose="NavState.HideAddConnectionStringModal"
                                      OnSave="SaveManualNamespace" />
        }

        <!-- Keyboard Shortcuts Modal -->
        <KeyboardShortcutsModal IsVisible="@DialogService.ShowKeyboardShortcutsModal"
                                IsDarkMode="@_isDarkMode"
                                OnClose="@(() => DialogService.ShowKeyboardShortcutsModal = false)" />
    };

    private DotNetObjectReference<MainLayout>? _selfReference;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfReference = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerKeyboardShortcuts", _selfReference);
        }
    }

    [JSInvokable]
    public async Task OnGlobalKeyDown(string key, bool ctrl)
    {
        var keyLower = key.ToLower();
        if (ctrl)
        {
            if (keyLower == "k")
            {
                DialogService.ShowKeyboardShortcutsModal = !DialogService.ShowKeyboardShortcutsModal;
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        if (key == "Escape" || keyLower == "escape")
        {
            if (DialogService.ShowKeyboardShortcutsModal)
                DialogService.ShowKeyboardShortcutsModal = false;
            else if (DialogService.ShowSendMessageModal)
                DialogService.ShowSendMessageModal = false;
            else if (DialogService.ShowMessageDetailModal)
                DialogService.ShowMessageDetailModal = false;
            else if (DialogService.ShowPeekLockModal)
                DialogService.ShowPeekLockModal = false;
            else if (DialogService.ShowMonitorModal)
                DialogService.ShowMonitorModal = false;
            else if (DialogService.ShowReceiveAndLockModal)
                DialogService.ShowReceiveAndLockModal = false;
            else if (DialogService.ShowPeekOptionsModal)
                DialogService.ShowPeekOptionsModal = false;
            else if (DialogService.ShowStatsModal)
                DialogService.ShowStatsModal = false;
            else if (DialogService.ShowExportOptionsModal)
                DialogService.ShowExportOptionsModal = false;
            else if (DialogService.ShowManageRulesModal)
                DialogService.ShowManageRulesModal = false;
            
            await InvokeAsync(StateHasChanged);
            return;
        }

        var uri = Navigation.Uri;
        if (!uri.Contains("/explorer")) return;

        if (keyLower == "r")
        {
            if (SelectionState.HasQueueOrSubscriptionSelected)
            {
                await PeekService.PeekMessagesAsync();
            }
        }
        else if (keyLower == "s")
        {
            if (SelectionState.HasEntitySelected && !SelectionState.State.IsViewingDLQ)
            {
                DialogService.ShowSendMessageModal = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        else if (keyLower == "m")
        {
            if (SelectionState.HasQueueOrSubscriptionSelected)
            {
                DialogService.ShowMonitorModal = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        else if (keyLower == "d")
        {
            await ToggleDarkMode();
            await InvokeAsync(StateHasChanged);
        }
        else if (key == "ArrowDown")
        {
            var messages = MessageListState.FilteredMessages;
            if (messages.Any())
            {
                if (MessageListState.NavigatedIndex < messages.Count - 1)
                {
                    MessageListState.NavigatedIndex++;
                    MessageListState.NotifyUpdate();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else if (key == "ArrowUp")
        {
            var messages = MessageListState.FilteredMessages;
            if (messages.Any())
            {
                if (MessageListState.NavigatedIndex > 0)
                {
                    MessageListState.NavigatedIndex--;
                    MessageListState.NotifyUpdate();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        else if (key == "Enter")
        {
            var messages = MessageListState.FilteredMessages;
            if (MessageListState.NavigatedIndex >= 0 && MessageListState.NavigatedIndex < messages.Count)
            {
                var msg = messages[MessageListState.NavigatedIndex];
                MessageListState.SelectedMessage = msg;
                DialogService.ShowMessageDetailModal = true;
                MessageListState.NotifyUpdate();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private BuildInfoModel? buildInfo;

    private string FormatBuildTime(string? buildTime)
    {
        if (string.IsNullOrEmpty(buildTime)) return "Unknown";
        if (DateTime.TryParse(buildTime, out var dt))
        {
            return dt.ToString("yyyy-MM-dd HH:mm UTC");
        }
        return buildTime;
    }

    private class BuildInfoModel
    {
        public string CommitHash { get; set; } = "";
        public string CommitShort { get; set; } = "";
        public string BuildTime { get; set; } = "";
        public string Branch { get; set; } = "";
        public string Repository { get; set; } = "";
        public string VerifyUrl { get; set; } = "";
    }
}
