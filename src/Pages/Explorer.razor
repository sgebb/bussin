@page "/explorer"
@using Microsoft.AspNetCore.Authorization
@using Azure.Core
@inject EntitySelectionState SelectionState
@inject MessageListState MessageListState
@inject PeekService PeekService
@inject SendService SendService
@inject MonitorService MonitorService
@inject SearchStateService SearchStateService
@inject ExplorerDialogService DialogService
@inject IAuthenticationService AuthService
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@inject NavigationStateService NavState
@inject IServiceBusJsInteropService JsInterop
@implements IDisposable

<PageTitle>Explorer - bussin</PageTitle>

<div class="explorer-layout">
    <!-- Section 1: Restructured Header -->
    <div class="explorer-header">
        <div class="explorer-header-left">
            @if (DialogService.IsEditingDisplayName)
            {
                <div class="namespace-edit-section">
                    <div class="namespace-edit-wrapper" data-value="@DialogService.EditDisplayName">
                        <input type="text" class="form-control namespace-rename-input"
                               @bind="DialogService.EditDisplayName"
                               @bind:event="oninput"
                               @onkeydown="HandleRenameKeyDown"
                               @onblur="CancelRename"
                               @ref="renameInputRef" />
                    </div>
                    <button class="btn btn-sm btn-success" @onmousedown="SaveDisplayNameAsync" @onmousedown:preventDefault="true" disabled="@string.IsNullOrWhiteSpace(DialogService.EditDisplayName)">
                        <i class="bi bi-check-lg"></i>
                    </button>
                    <button class="btn btn-sm btn-secondary" @onmousedown="CancelRename" @onmousedown:preventDefault="true">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }
            else
            {
                <div class="namespace-title-section">
                    <div class="namespace-title-row">
                        <h1 class="explorer-namespace-title @(SelectionState.IsFavorite ? "editable" : "")" 
                            @onclick="@(SelectionState.IsFavorite ? StartRename : (Action)(() => {}))"
                            title="@(SelectionState.IsFavorite ? "Click to rename" : SelectionState.DisplayName)">
                            @SelectionState.DisplayName
                        </h1>
                        <button class="namespace-action-btn favorite-toggle-btn @(SelectionState.IsFavorite ? "favorited" : "not-favorited")"
                                @onclick="SelectionState.ToggleFavoriteAsync"
                                title="@(SelectionState.IsFavorite ? "Remove from favorites" : "Add to favorites")">
                            <i class="bi @(SelectionState.IsFavorite ? "bi-star-fill" : "bi-star")"></i>
                        </button>
                        @if (SelectionState.IsConnectionStringMode)
                        {
                            var currentConn = NavState.GetNamespaceConnection(SelectionState.State.FullyQualifiedNamespace ?? NamespaceParam ?? "");
                            if (currentConn != null)
                            {
                                <button class="namespace-action-btn edit-connection-btn ms-2"
                                        @onclick="@(() => NavState.ShowAddConnectionStringModalDialog(currentConn))"
                                        title="Edit connection settings">
                                    <i class="bi bi-gear-fill"></i>
                                </button>
                            }
                        }
                    </div>
                </div>
            }
            <div class="namespace-fqdn-below">
                @NamespaceParam
            </div>
        </div>
        <div class="explorer-header-right">
            <div class="header-action-buttons">
                @if (SelectionState.IsLoadingEntities)
                {
                    <div class="spinner-border spinner-border-sm text-muted" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                }
                else if (!SelectionState.IsConnectionStringMode)
                {
                    <button class="namespace-action-btn refresh-btn" @onclick="SelectionState.RefreshEntitiesAsync" title="Refresh queues and topics">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                }
                @if (!SelectionState.IsConnectionStringMode)
                {
                    <button class="namespace-action-btn stats-btn" @onclick="() => DialogService.ShowStatsModal = true" title="Statistics">
                        <i class="bi bi-bar-chart-line"></i>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Section 2: Compact Entity Selector (3 Columns) -->
    @if (SelectionState.Queues.Count > 0 || SelectionState.Topics.Count > 0 || SelectionState.IsConnectionStringMode)
    {
        <ExplorerEntitySelector Queues="@SelectionState.Queues"
                                Topics="@SelectionState.Topics"
                                Subscriptions="@SelectionState.Subscriptions"
                                SelectedQueueName="@SelectionState.State.SelectedQueueName"
                                SelectedTopicName="@SelectionState.State.SelectedTopicName"
                                SelectedSubscriptionName="@SelectionState.State.SelectedSubscriptionName"
                                IsLoadingSubscriptions="@SelectionState.IsLoadingSubscriptions"
                                IsConnectionStringMode="@SelectionState.IsConnectionStringMode"
                                OnQueueSelected="@SelectionState.SelectQueue"
                                OnTopicSelected="@SelectionState.SelectTopic"
                                OnSubscriptionSelected="@SelectionState.SelectSubscription"
                                OnAddQueue="TriggerAddQueue"
                                OnAddTopic="TriggerAddTopic"
                                OnAddSubscription="TriggerAddSubscription"
                                OnDeleteQueue="HandleDeleteQueue"
                                OnDeleteTopic="HandleDeleteTopic"
                                OnDeleteSubscription="HandleDeleteSubscription" />

    }

    <!-- Section 3: Messages (Takes Majority of Space) -->
    <div class="explorer-messages">
        <div class="explorer-messages-header">
            <!-- Header removed - just the message list -->
        </div>

        <div class="explorer-messages-content">
            <div class="explorer-messages-main">


                <div class="explorer-messages-list">
                    @if (MessageListState.PeekedMessages.Count > 0)
                    {
                        <MessageList @ref="_messageListRef"
                                     Messages="@MessageListState.PeekedMessages"
                                     IsDLQ="@SelectionState.State.IsViewingDLQ"
                                     IsProcessing="@PeekService.IsProcessingBatch"
                                     RequiresSession="@SelectionState.SelectedEntityRequiresSession"
                                     ColumnPreferenceKey="@GetColumnPreferenceKey()"
                                     OnMessageSelected="@ShowMessageDetail"
                                     OnDeleteMessages="@PeekService.DeleteMessages"
                                     OnResubmitMessages="@PeekService.ResubmitMessages"
                                     OnMoveToDLQMessages="@PeekService.MoveToDLQMessages"
                                     OnScheduledMessageWarning="@ShowScheduledMessageWarning"
                                     OnClearMessages="@(() => MessageListState.Clear())"
                                     OnDownloadSelected="@PeekService.DownloadSelectedMessagesAsync"
                                     OnDownloadLoaded="@PeekService.DownloadLoadedMessagesAsync"
                                     OnDownloadEntireEntity="@PeekService.DownloadEntireEntityMessagesAsync" />
                    }
                    else if (SelectionState.State.SelectedQueueName != null || SelectionState.State.SelectedSubscriptionName != null)
                    {
                        <div class="text-center text-muted p-4">
                            <p>@(MessageListState.HasPeeked ? "No messages found" : "Click 'Peek' to load messages")</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted p-4">
                            <p>Select a queue or topic subscription to view messages</p>
                        </div>
                    }
                </div>
            </div>

            <ExplorerActionsSidebar IsViewingDLQ="@SelectionState.State.IsViewingDLQ"
                                    CanSend="@(SelectionState.HasEntitySelected && !SelectionState.State.IsViewingDLQ)"
                                    HasQueueOrSubscriptionSelected="@SelectionState.HasQueueOrSubscriptionSelected"
                                    IsPeeking="@PeekService.IsPeeking"
                                    PeekedMessagesCount="@MessageListState.PeekedMessages.Count"
                                    ArePeekOptionsModified="@MessageListState.ArePeekOptionsModified"
                                    CurrentPurgeOperation="@PeekService.CurrentPurgeOperation"
                                    CurrentResubmitOperation="@PeekService.CurrentResubmitOperation"
                                    SelectedEntityRequiresSession="@SelectionState.SelectedEntityRequiresSession"
                                    IsSubscriptionSelected="@SelectionState.State.IsSubscriptionSelected"
                                    SelectedSubscriptionHasAutoforwarding="@(SelectionState.State.SelectedSubscriptionName != null && SelectionState.SubscriptionDict.TryGetValue(SelectionState.State.SelectedSubscriptionName, out var sidebarSub) && !string.IsNullOrEmpty(sidebarSub.ForwardTo))"
                                    OnShowSendMessage="@(() => DialogService.ShowSendMessageModal = true)"
                                    OnToggleDLQ="@SelectionState.ToggleDLQ"
                                    OnPeek="@(() => PeekService.PeekMessagesAsync())"
                                    OnPeekNext="@(() => PeekService.PeekMessagesAsync(append: true))"
                                    OnShowPeekOptions="@(() => DialogService.ShowPeekOptionsModal = true)"
                                    OnResubmitAll="@PeekService.ResubmitAllMessages"
                                    OnPurge="@(() => PeekService.PurgeMessages())"
                                    OnManageFilters="@(() => DialogService.ShowManageRulesModal = true)"
                                    OnStartLiveMonitor="@(() => DialogService.ShowMonitorModal = true)" />

        </div>
        
        @{
            var errorMsg = PeekService.ErrorMessage ?? SendService.ErrorMessage ?? SelectionState.ErrorMessage;
            var rawErrorMsg = PeekService.RawErrorMessage ?? SendService.RawErrorMessage ?? SelectionState.RawErrorMessage;
        }
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            @if (PermissionErrorHelper.IsPermissionError(rawErrorMsg ?? ""))
            {
                var permissionType = PermissionErrorHelper.GetPermissionType(rawErrorMsg ?? "");
                var roles = PermissionErrorHelper.GetRecommendedRoles(permissionType);
                <div class="alert alert-warning alert-dismissible mt-2">
                    <button type="button" class="btn-close" @onclick="ClearError"></button>
                    <div class="d-flex align-items-start">
                        <i class="bi bi-shield-exclamation me-2 fs-5"></i>
                        <div>
                            <strong>@errorMsg</strong>
                            <div class="mt-2">
                                <small>To perform this operation, you need one of these Azure RBAC roles:</small>
                                <ul class="mb-2 mt-1">
                                    @foreach (var role in roles)
                                    {
                                        <li><code>@role</code></li>
                                    }
                                </ul>
                            </div>
                            <details class="mt-2">
                                <summary class="text-muted" style="cursor: pointer; font-size: 0.8rem;">
                                    <i class="bi bi-code-slash me-1"></i>Technical details
                                </summary>
                                <pre class="mt-1 p-2 bg-dark text-light rounded" style="font-size: 0.75rem; white-space: pre-wrap; word-break: break-all; max-height: 100px; overflow-y: auto;">@rawErrorMsg</pre>
                            </details>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-danger alert-dismissible alert-sm mt-2" style="max-height: 120px; overflow-y: auto;">
                    <button type="button" class="btn-close" @onclick="ClearError"></button>
                    <strong>Error:</strong> @errorMsg
                </div>
            }
        }
    </div>
</div>

<!-- Modals -->
<SendMessageModal IsVisible="@DialogService.ShowSendMessageModal"
                  IsSending="@SendService.IsSending"
                  RequiresSession="@SelectionState.SelectedEntityRequiresSession"
                  OnClose="@(() => DialogService.ShowSendMessageModal = false)"
                  OnSend="@HandleSendAsync" 
                  OnBatchSend="@HandleBatchSendAsync" />

<MessageDetailModal IsVisible="@DialogService.ShowMessageDetailModal"
                    Message="@MessageListState.SelectedMessage"
                    IsDLQ="@SelectionState.State.IsViewingDLQ"
                    IsProcessing="@PeekService.IsProcessingBatch"
                    RequiresSession="@SelectionState.SelectedEntityRequiresSession"
                    OnClose="@DialogService.CloseMessageDetail"
                    OnDelete="@PeekService.DeleteSingleMessage"
                    OnResubmit="@PeekService.ResubmitSingleMessage"
                    OnMoveToDLQ="@PeekService.MoveToDLQSingleMessage"
                    OnEditResubmit="@SendService.EditAndResubmitMessageAsync" />

<PeekLockModal IsVisible="@DialogService.ShowPeekLockModal"
               IsProcessing="@PeekService.IsPeeking"
               InitialCount="@PeekService.PeekLockCount"
               InitialDuration="@PeekService.PeekLockDuration"
               OnClose="@(() => DialogService.ShowPeekLockModal = false)"
               OnPeekLock="@PeekService.PeekLockMessagesWithSettings" />

<PeekOptionsModal IsVisible="@DialogService.ShowPeekOptionsModal"
                  OnClose="@(() => DialogService.ShowPeekOptionsModal = false)"
                  InitialOptions="@MessageListState.LastPeekOptions"
                  MessageCount="@SelectionState.CurrentEntityMessageCount"
                  IsViewingDLQ="@SelectionState.State.IsViewingDLQ"
                  RequiresSession="@SelectionState.SelectedEntityRequiresSession"
                  NamespaceName="@SelectionState.NamespaceNameOnly"
                  EntityPath="@SelectionState.State.GetEntityPath()"
                  OnPeek="@(async (options) => await PeekService.PeekWithOptionsAsync(options, append: false))"
                  OnBackgroundSearch="@SearchStateService.StartBackgroundSearchAsync"
                  OnStartLiveMonitor="@(() => DialogService.ShowMonitorModal = true)" />

<MessageMonitorModal IsVisible="@DialogService.ShowMonitorModal"
                     NamespaceName="@SelectionState.NamespaceNameOnly"
                     QueueName="@SelectionState.State.SelectedQueueName"
                     TopicName="@SelectionState.State.SelectedTopicName"
                     SubscriptionName="@SelectionState.State.SelectedSubscriptionName"
                     OnClose="@(() => DialogService.ShowMonitorModal = false)" />

<ReceiveAndLockModal IsVisible="@DialogService.ShowReceiveAndLockModal"
                     OnClose="@(() => DialogService.ShowReceiveAndLockModal = false)"
                     RequiresSession="@SelectionState.SelectedEntityRequiresSession"
                     OnLockMessages="@PeekService.LockMessagesForModalAsync" />

<ManageRulesModal IsVisible="@DialogService.ShowManageRulesModal"
                  NamespaceName="@SelectionState.NamespaceNameOnly"
                  TopicName="@SelectionState.State.SelectedTopicName"
                  SubscriptionName="@SelectionState.State.SelectedSubscriptionName"
                  EntityPath="@SelectionState.State.GetEntityPath()"
                  IsAutoForwardingEnabled="@(SelectionState.State.SelectedSubscriptionName != null && SelectionState.SubscriptionDict.TryGetValue(SelectionState.State.SelectedSubscriptionName, out var modalSub) && !string.IsNullOrEmpty(modalSub.ForwardTo))"
                  OnClose="@(() => DialogService.ShowManageRulesModal = false)" />

<ExportOptionsModal IsVisible="@DialogService.ShowExportOptionsModal"
                    Options="@DialogService.MessageExportOptions"
                    OnClose="@(() => DialogService.ShowExportOptionsModal = false)"
                    OnExport="@PeekService.ExecuteExportAsync" />

<ConfirmModal IsVisible="@DialogService.ConfirmModalVisible"
              Title="@DialogService.ConfirmModalTitle"
              Message="@DialogService.ConfirmModalMessage"
              DetailMessage="@DialogService.ConfirmModalDetailMessage"
              ConfirmButtonText="@DialogService.ConfirmModalConfirmButtonText"
              ConfirmButtonClass="@DialogService.ConfirmModalConfirmButtonClass"
              AlternativeConfirmButtonText="@DialogService.ConfirmModalAlternativeButtonText"
              AlternativeConfirmButtonClass="@DialogService.ConfirmModalAlternativeButtonClass"
              IsProcessing="@DialogService.ConfirmModalIsProcessing"
              ProgressCount="@DialogService.ConfirmModalProgressCount"
              OnConfirm="@DialogService.OnConfirmModalConfirmAsync"
              OnAlternativeConfirm="@DialogService.OnConfirmModalAlternativeConfirmAsync"
              OnCancel="@DialogService.OnConfirmModalCancelAsync">
    @if (DialogService.IsResubmitModal)
    {
        <div class="resubmit-delete-option mt-3 p-3 rounded">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="removeFromDlq" @bind="DialogService.ResubmitRemoveFromDLQ">
                <label class="form-check-label" for="removeFromDlq">
                    <strong>Delete from Dead Letter Queue after resubmit</strong>
                    <small class="d-block text-muted">This will permanently remove the message from the DLQ</small>
                </label>
            </div>
        </div>
    }
    @if (DialogService.IsMoveToDLQModal)
    {
        <div class="dlq-customization mt-3 p-3 rounded border border-warning" style="background: rgba(255, 193, 7, 0.05); backdrop-filter: blur(10px);">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-exclamation-triangle-fill text-warning me-2" style="font-size: 1.1rem;"></i>
                <h6 class="mb-0 text-warning fw-semibold">Dead Letter Metadata</h6>
            </div>
            <div class="mb-3">
                <label for="dlqReasonInput" class="form-label fw-medium text-secondary" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">Dead Letter Reason</label>
                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" id="dlqReasonInput" @bind="DialogService.MoveToDLQReason" placeholder="Manual move to DLQ" />
            </div>
            <div class="mb-0">
                <label for="dlqDescInput" class="form-label fw-medium text-secondary" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">Error Description</label>
                <textarea class="form-control form-control-sm bg-dark text-white border-secondary" id="dlqDescInput" rows="2" @bind="DialogService.MoveToDLQErrorDescription" placeholder="Moved by user"></textarea>
            </div>
        </div>
    }
</ConfirmModal>

<StatsModal IsVisible="@DialogService.ShowStatsModal"
            NamespaceInfo="@SelectionState.State.CurrentNamespace"
            Queues="@SelectionState.Queues"
            Topics="@SelectionState.Topics"
            OnClose="@(() => DialogService.ShowStatsModal = false)" />

<AddEntityModal IsVisible="@showAddEntityModal"
                Title="@addEntityTitle"
                Label="@addEntityLabel"
                Placeholder="@addEntityPlaceholder"
                OnClose="@(() => showAddEntityModal = false)"
                OnSubmit="HandleAddEntitySubmit" />

@code {
    [SupplyParameterFromQuery(Name = "namespace")]
    public string? NamespaceParam { get; set; }

    [SupplyParameterFromQuery(Name = "rg")]
    public string? ResourceGroupParam { get; set; }

    [SupplyParameterFromQuery(Name = "sub")]
    public string? SubscriptionIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "name")]
    public string? NameParam { get; set; }

    [SupplyParameterFromQuery(Name = "queue")]
    public string? QueueParam { get; set; }

    [SupplyParameterFromQuery(Name = "topic")]
    public string? TopicParam { get; set; }

    [SupplyParameterFromQuery(Name = "subscription")]
    public string? SubscriptionParam { get; set; }

    [SupplyParameterFromQuery(Name = "dlq")]
    public bool DlqParam { get; set; }

    private ElementReference renameInputRef;
    private MessageList? _messageListRef;

    private string? GetColumnPreferenceKey()
    {
        var ns = SelectionState.State.FullyQualifiedNamespace;
        if (string.IsNullOrEmpty(ns)) return null;
        var entity = SelectionState.State.SelectedQueueName
            ?? (SelectionState.State.SelectedTopicName != null && SelectionState.State.SelectedSubscriptionName != null
                ? $"{SelectionState.State.SelectedTopicName}/{SelectionState.State.SelectedSubscriptionName}"
                : null);
        if (entity == null) return null;
        return AppPreferences.BuildColumnPreferenceKey(ns, entity);
    }

    private bool showAddEntityModal = false;
    private string addEntityTitle = "";
    private string addEntityLabel = "";
    private string addEntityPlaceholder = "";
    private Func<string, Task>? addEntitySubmitHandler;

    private readonly HashSet<string> _loadedSubscriptionRules = new();
    private string? _currentNamespace;
    private string? _lastSelectedTopic;

    protected override async Task OnParametersSetAsync()
    {
        bool nsChanged = NamespaceParam != _currentNamespace;
        if (nsChanged)
        {
            _currentNamespace = NamespaceParam;
            lock (_loadedSubscriptionRules)
            {
                _loadedSubscriptionRules.Clear();
            }
            MessageListState.Clear();
        }

        await SelectionState.InitializeAsync(
            NamespaceParam, 
            ResourceGroupParam, 
            SubscriptionIdParam, 
            NameParam,
            QueueParam,
            TopicParam,
            SubscriptionParam,
            DlqParam);
        
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated && !SelectionState.IsConnectionStringMode)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void TriggerAddQueue()
    {
        addEntityTitle = "Register Queue";
        addEntityLabel = "Queue Name";
        addEntityPlaceholder = "e.g. order-processing";
        addEntitySubmitHandler = async (name) => {
            await SelectionState.RegisterQueueAsync(name);
        };
        showAddEntityModal = true;
    }

    private void TriggerAddTopic()
    {
        addEntityTitle = "Register Topic";
        addEntityLabel = "Topic Name";
        addEntityPlaceholder = "e.g. invoice-events";
        addEntitySubmitHandler = async (name) => {
            await SelectionState.RegisterTopicAsync(name);
        };
        showAddEntityModal = true;
    }

    private void TriggerAddSubscription()
    {
        if (string.IsNullOrEmpty(SelectionState.State.SelectedTopicName)) return;
        addEntityTitle = $"Register Subscription for '{SelectionState.State.SelectedTopicName}'";
        addEntityLabel = "Subscription Name";
        addEntityPlaceholder = "e.g. invoice-billing-service";
        addEntitySubmitHandler = async (name) => {
            await SelectionState.RegisterSubscriptionAsync(SelectionState.State.SelectedTopicName, name);
        };
        showAddEntityModal = true;
    }

    private async Task HandleAddEntitySubmit(string entityName)
    {
        if (addEntitySubmitHandler != null)
        {
            await addEntitySubmitHandler(entityName);
            showAddEntityModal = false;
        }
    }

    private void HandleDeleteQueue(string name)
    {
        SelectionState.UnregisterQueue(name);
    }

    private void HandleDeleteTopic(string name)
    {
        SelectionState.UnregisterTopic(name);
    }

    private void HandleDeleteSubscription((string Topic, string Subscription) args)
    {
        SelectionState.UnregisterSubscription(args.Topic, args.Subscription);
    }

    protected override void OnInitialized()
    {
        SelectionState.OnChange += OnSelectionStateChange;
        MessageListState.OnChange += StateHasChanged;
        PeekService.OnChange += StateHasChanged;
        SendService.OnChange += StateHasChanged;
        DialogService.OnChange += StateHasChanged;
        MonitorService.OnChange += StateHasChanged;
        SearchStateService.OnChange += StateHasChanged;

        SelectionState.OnEntitySelectionChanged += () =>
        {
            MessageListState.Clear();
            if (_messageListRef != null) 
                _messageListRef.ClearSelection();
        };
    }

    private void StartRename()
    {
        DialogService.EditDisplayName = SelectionState.DisplayName;
        DialogService.IsEditingDisplayName = true;
        _ = FocusRenameInputAsync();
    }

    private async Task FocusRenameInputAsync()
    {
        await Task.Delay(10); // Wait for render
        try { await renameInputRef.FocusAsync(); } catch { }
    }

    private void CancelRename()
    {
        DialogService.IsEditingDisplayName = false;
        DialogService.EditDisplayName = "";
    }

    private async Task SaveDisplayNameAsync()
    {
        if (string.IsNullOrWhiteSpace(DialogService.EditDisplayName) || string.IsNullOrEmpty(SelectionState.State.FullyQualifiedNamespace)) return;
        await NavState.RenameNamespaceAsync(SelectionState.State.FullyQualifiedNamespace, DialogService.EditDisplayName.Trim());
        SelectionState.DisplayName = DialogService.EditDisplayName.Trim();
        DialogService.IsEditingDisplayName = false;
        DialogService.EditDisplayName = "";
        NotificationService.NotifySuccess("Namespace renamed successfully.");
    }

    private async Task HandleRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveDisplayNameAsync();
        else if (e.Key == "Escape") CancelRename();
    }

    private void ShowMessageDetail(ServiceBusMessage message)
    {
        MessageListState.SelectedMessage = message;
        DialogService.ShowMessageDetailModal = true;
    }

    private void ShowScheduledMessageWarning(string message)
    {
        NotificationService.NotifyWarning(message);
    }

    private async Task HandleSendAsync(SendMessageModal.SendMessageRequest request)
    {
        await SendService.SendMessageAsync(request);
        if (SendService.ErrorMessage == null)
        {
            DialogService.ShowSendMessageModal = false;
        }
    }

    private async Task HandleBatchSendAsync(List<SendMessageModal.SendMessageRequest> requests)
    {
        await SendService.SendBatchMessagesAsync(requests);
        if (SendService.ErrorMessage == null)
        {
            DialogService.ShowSendMessageModal = false;
        }
    }

    private void ClearError()
    {
        PeekService.ClearError();
        SendService.ClearError();
        SelectionState.ErrorMessage = null;
        SelectionState.RawErrorMessage = null;
    }

    public void Dispose()
    {
        SelectionState.OnChange -= OnSelectionStateChange;
        MessageListState.OnChange -= StateHasChanged;
        PeekService.OnChange -= StateHasChanged;
        SendService.OnChange -= StateHasChanged;
        DialogService.OnChange -= StateHasChanged;
        MonitorService.OnChange -= StateHasChanged;
        SearchStateService.OnChange -= StateHasChanged;
    }



    private void OnSelectionStateChange()
    {
        // Whenever subscriptions change or load, lazy-load rules for any subscriptions that aren't loaded yet
        var currentTopic = SelectionState.State.SelectedTopicName;
        if (currentTopic != _lastSelectedTopic)
        {
            _lastSelectedTopic = currentTopic;
            lock (_loadedSubscriptionRules)
            {
                _loadedSubscriptionRules.Clear();
            }
        }

        if (!string.IsNullOrEmpty(currentTopic) && currentTopic == SelectionState.LoadedSubscriptionsForTopic)
        {
            var subs = SelectionState.Subscriptions;
            foreach (var sub in subs)
            {
                string ruleKey = $"{currentTopic}/{sub.Name}";
                bool alreadyLoaded;
                lock (_loadedSubscriptionRules)
                {
                    alreadyLoaded = _loadedSubscriptionRules.Contains(ruleKey);
                }

                if (!alreadyLoaded)
                {
                    // Fire and forget on the UI thread
                    _ = LazyLoadSubscriptionRulesAsync(currentTopic, sub.Name);
                }
            }
        }
        
        StateHasChanged();
    }

    private async Task LazyLoadSubscriptionRulesAsync(string topicName, string subscriptionName)
    {
        string ruleKey = $"{topicName}/{subscriptionName}";
        lock (_loadedSubscriptionRules)
        {
            if (_loadedSubscriptionRules.Contains(ruleKey)) return;
            _loadedSubscriptionRules.Add(ruleKey);
        }

        try
        {
            if (SelectionState.State.SelectedTopicName != topicName) return;

            // Check if subscription has auto-forwarding enabled
            if (SelectionState.SubscriptionDict.TryGetValue(subscriptionName, out var sub) && !string.IsNullOrEmpty(sub.ForwardTo))
            {
                if (SelectionState.State.SelectedTopicName == topicName)
                {
                    SelectionState.SubscriptionDict[subscriptionName] = sub with
                    {
                        HasCustomFilter = false,
                        CustomFilterTooltip = "Filters cannot be loaded via AMQP on auto-forwarded subscriptions"
                    };
                    await InvokeAsync(StateHasChanged);
                }
                return;
            }

            // Get token for the subscription path
            string entityPath = $"{topicName}/subscriptions/{subscriptionName}";
            string token = await PeekService.GetTokenAsync(entityPath);
            if (string.IsNullOrEmpty(token)) return;

            if (SelectionState.State.SelectedTopicName != topicName) return;

            var rules = await JsInterop.EnumerateRulesAsync(SelectionState.NamespaceNameOnly, topicName, subscriptionName, token);
            
            if (SelectionState.State.SelectedTopicName != topicName) return;

            if (rules != null)
            {
                // Check if there are rules other than the default rule
                var customRules = rules.Where(r => r.Name != "$Default").ToList();
                bool hasCustom = customRules.Any();

                if (SelectionState.State.SelectedTopicName == topicName &&
                    SelectionState.SubscriptionDict.TryGetValue(subscriptionName, out var subInfo))
                {
                    string? tooltip = null;
                    if (hasCustom)
                    {
                        tooltip = string.Join("\n", customRules.Select(r => 
                            $"{r.Name}: {(!string.IsNullOrEmpty(r.SqlExpression) ? r.SqlExpression : (r.FilterType == "Correlation" ? "Correlation" : r.FilterType))}"
                        ));
                    }

                    // Update subInfo in dictionary
                    SelectionState.SubscriptionDict[subscriptionName] = subInfo with 
                    { 
                        HasCustomFilter = hasCustom, 
                        CustomFilterTooltip = tooltip 
                    };
                    
                    // Trigger state change so selector updates
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception ex)
        {
            if (SelectionState.State.SelectedTopicName == topicName)
            {
                Console.WriteLine($"Error lazy loading rules for {ruleKey}: {ex.Message}");
            }
            else
            {
                // If we navigated away, remove from cache so we can retry if we navigate back
                lock (_loadedSubscriptionRules)
                {
                    _loadedSubscriptionRules.Remove(ruleKey);
                }
            }
        }
    }
}
