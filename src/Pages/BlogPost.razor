@page "/blog/{slug}"
@layout BlogLayout
@inject HttpClient Http

@if (article != null)
{
    <PageTitle>@article.Title | Bussin Blog</PageTitle>

    <div class="article-page">
        <header class="article-header">
            <div class="article-header-inner">
                <a href="/blog" class="header-brand"><strong>bussin</strong><span class="header-sep">/</span><span class="header-section">blog</span></a>
                <a href="/blog" class="header-back">← All articles</a>
                <span class="header-spacer"></span>
                <a href="/" class="header-cta">Open Bussin ↗</a>
            </div>
        </header>

        <main class="article-main">
            <span class="tag">@article.Tag</span>
            <h1>@article.Title</h1>
            <p class="lead">@article.Description</p>
            @((MarkupString)article.Content)
        </main>

        <footer class="article-footer">
            <div class="article-footer-inner">
                <a href="/blog" class="footer-back">← All articles</a>
                <a href="/" class="footer-cta">Open Bussin ↗</a>
            </div>
        </footer>
    </div>
}
else if (error)
{
    <div class="p-5 text-center">
        <h1>Article Not Found</h1>
        <p>Sorry, that article doesn't exist.</p>
        <a href="/blog" class="btn btn-primary mt-3">Back to Blog</a>
    </div>
}

<style>
    /* ── Reset ── */
    .article-page { all: initial; display: block; font-family: 'Inter', system-ui, sans-serif; background: #f8fafc; color: #0f172a; min-height: 100vh; }
    .article-page *, .article-page *::before, .article-page *::after { box-sizing: border-box; }

    /* ── Fixed header ── */
    .article-header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 52px; background: #fff; border-bottom: 1px solid #e2e8f0; }
    .article-header-inner { height: 100%; display: flex; align-items: center; padding: 0 1.5rem; gap: 1.25rem; }
    .brand-root { color: #0d6efd; text-decoration: none !important; font-weight: 800; }
    .brand-root strong { color: #0d6efd; }
    .header-sep { color: #d1d5db; margin: 0 0.2rem; font-weight: 300; }
    .header-section { color: #6b7280; font-weight: 500; text-decoration: none !important; }
    .header-section:hover { color: #0f172a; }
    .header-back { font-size: 0.8rem; color: #6b7280; text-decoration: none; font-weight: 500; flex-shrink: 0; }
    .header-back:hover { color: #0f172a; }
    .header-spacer { flex: 1; }
    .header-cta { flex-shrink: 0; font-size: 0.8rem; font-weight: 700; color: #fff; background: #0f172a; padding: 0.45rem 1rem; border-radius: 6px; text-decoration: none; letter-spacing: 0.01em; transition: background 0.15s; }
    .header-cta:hover { background: #0d6efd; }

    /* ── Article body ── */
    .article-main { max-width: 800px; margin: 0 auto; padding: 72px 2rem 5rem; }

    .tag { display: inline-block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #0d6efd; background: #eff6ff; padding: 0.18rem 0.5rem; border-radius: 99px; margin-bottom: 1.1rem; }
    h1 { font-size: 2.25rem; font-weight: 900; color: #0f172a; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1rem; }
    .lead { font-size: 1.1rem; color: #475569; line-height: 1.7; margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid #e2e8f0; }
    
    .article-main h2 { font-size: 1.35rem; font-weight: 800; color: #0f172a; margin: 2.25rem 0 0.65rem; }
    .article-main h3 { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin: 1.5rem 0 0.5rem; }
    .article-main p { font-size: 1rem; color: #334155; line-height: 1.75; margin-bottom: 1.1rem; }
    .article-main ul, .article-main ol { color: #334155; font-size: 1rem; line-height: 1.75; padding-left: 1.5rem; margin-bottom: 1.25rem; }
    .article-main li { margin-bottom: 0.35rem; }
    .article-main strong { color: #0f172a; }
    .article-main code { background: #f1f5f9; color: #0f172a; padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.875em; font-family: monospace; }
    .article-main a { color: #0d6efd; text-decoration: none; }
    .article-main a:hover { text-decoration: underline; }

    .callout { background: #f0f7ff; border-left: 3px solid #0d6efd; border-radius: 6px; padding: 1rem 1.25rem; margin: 1.75rem 0; color: #1e3a5f; font-size: 0.95rem; line-height: 1.65; }
    .tool-box { background: #fff; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
    .tool-box.recommended { border-color: #bfdbfe; background: #f0f7ff; }

    /* ── Footer ── */
    .article-footer { background: #fff; border-top: 1px solid #e2e8f0; padding: 1rem 2rem; }
    .article-footer-inner { max-width: 960px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    .footer-back { font-size: 0.85rem; color: #64748b; text-decoration: none; font-weight: 500; }
    .footer-back:hover { color: #0f172a; }
    .footer-cta { font-size: 0.8rem; font-weight: 700; color: #fff; background: #0f172a; padding: 0.4rem 0.9rem; border-radius: 6px; text-decoration: none; transition: background 0.15s; }
    .footer-cta:hover { background: #0d6efd; }
</style>

@code {
    [Parameter] public string slug { get; set; } = "";
    private BlogArticle? article;
    private bool error;

    protected override async Task OnParametersSetAsync()
    {
        try 
        {
            var articles = await Http.GetFromJsonAsync<List<BlogArticle>>($"blog/data/articles.json?v={DateTime.Now.Ticks}");
            article = articles?.FirstOrDefault(a => a.Slug == slug);
            error = (article == null);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading article: {ex.Message}");
            error = true;
        }
    }
}
