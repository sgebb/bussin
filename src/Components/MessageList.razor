@using Bussin.Models
@using System.Text.RegularExpressions
@inject MessageListState MessageListState
@inject IJSRuntime JSRuntime
@inject IPreferencesService PreferencesService


<div class="message-list">
    @if (Messages.Any())
    {
        <!-- Sticky header for selection controls -->
        <div class="message-list-header">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="form-check me-3">
                        <input class="form-check-input" type="checkbox" id="selectAll" 
                               @onchange="ToggleSelectAll" checked="@allSelected">
                        <label class="form-check-label fw-bold" for="selectAll">
                            Select All (@SelectedMessages.Count)
                        </label>
                    </div>
                </div>
                
                <div class="d-flex align-items-center">
                    @if (SelectedMessages.Any())
                    {
                        <div class="btn-group btn-group-sm me-2">
                            <button class="btn btn-danger" @onclick="OnDeleteSelected" disabled="@IsProcessing" 
                                    title="Delete selected messages">
                                Delete
                            </button>
                            @if (IsDLQ)
                            {
                                <button class="btn btn-success" @onclick="OnResubmitSelected" disabled="@IsProcessing">
                                    Resubmit
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-warning" @onclick="OnMoveToDLQSelected" disabled="@IsProcessing"
                                        title="Move to DLQ">
                                    To DLQ
                                </button>
                            }
                        </div>
                    }

                    <div class="message-search me-2">
                        <input type="text" class="form-control form-control-sm" 
                               placeholder="Search messages..." 
                               @bind="SearchTerm" 
                               @bind:event="oninput" />
                        <i class="bi bi-search message-search-icon big-icon" style="font-size: 0.8rem;"></i>
                    </div>
                    
                    @if (SelectedMessages.Any())
                    {
                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="DownloadSelected" title="Download selected messages as JSON">
                            <i class="bi bi-download"></i> Download Selected (@SelectedMessages.Count)
                        </button>
                    }
                    else
                    {
                        <div class="dropdown me-2" style="position: relative;">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" @onclick="ToggleDownloadDropdown" type="button" title="Download options">
                                <i class="bi bi-download"></i> Download
                            </button>
                            @if (showDownloadDropdown)
                            {
                                <div style="position: fixed; inset: 0; z-index: 1040;" @onclick="() => showDownloadDropdown = false"></div>
                                <ul class="dropdown-menu show" style="display: block; position: absolute; right: 0; left: auto; top: 100%; z-index: 1050; min-width: 210px; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);" @onclick:stopPropagation="true">
                                    <li><button class="dropdown-item py-2" style="font-size: 0.85rem;" @onclick="DownloadLoaded">Download Loaded (@Messages.Count)</button></li>
                                    <li><button class="dropdown-item py-2" style="font-size: 0.85rem;" @onclick="DownloadEntireEntity">Download Queue/Sub (Max 10k)</button></li>
                                </ul>
                            }
                        </div>
                    }

                    <button class="btn btn-sm btn-outline-secondary" @onclick="OnClearMessagesClick" title="Clear all peeked messages">
                        <i class="bi bi-trash"></i> Clear
                    </button>

                    <div class="dropdown ms-2" style="position: relative;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleColumnDropdown" type="button" title="Configure visible properties">
                            <i class="bi bi-tags"></i> Properties
                        </button>
                        @if (_showColumnDropdown)
                        {
                            <div style="position: fixed; inset: 0; z-index: 1040;" @onclick="() => _showColumnDropdown = false"></div>
                            <div class="column-dropdown" style="position: absolute; right: 0; top: 100%; z-index: 1050;" @onclick:stopPropagation="true">
                                <div class="column-dropdown-header">
                                    <strong>Visible properties</strong>
                                    <button class="btn-close" @onclick="() => _showColumnDropdown = false"></button>
                                </div>
                                <div class="column-dropdown-list">
                                    @foreach (var key in AlwaysOnProperties)
                                    {
                                        <label class="column-dropdown-item column-dropdown-item-locked" title="Always visible">
                                            <input type="checkbox" checked disabled />
                                            <span>@key</span>
                                            <i class="bi bi-lock ms-auto" style="font-size: 0.7rem; opacity: 0.45;"></i>
                                        </label>
                                    }
                                    @if (_discoveredAppProperties.Any(k => !AlwaysShownDlqProps.Contains(k)))
                                    {
                                        <div class="column-dropdown-divider"></div>
                                        @foreach (var key in _discoveredAppProperties.Where(k => !AlwaysShownDlqProps.Contains(k)).OrderBy(k => k))
                                        {
                                            var isChecked = _activeColumns.Contains(key);
                                            <label class="column-dropdown-item">
                                                <input type="checkbox" checked="@isChecked"
                                                       @onchange="() => ToggleColumn(key)" />
                                                <span>@key</span>
                                            </label>
                                        }
                                    }
                                    else if (!_discoveredAppProperties.Any())
                                    {
                                        <div class="column-dropdown-empty">No custom properties in loaded messages.</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="list-group">
            @{
                var displayed = DisplayedMessages;
            }
            @for (int i = 0; i < displayed.Count; i++)
            {
                var index = i;
                var message = displayed[index];
                var isSelected = message.SequenceNumber.HasValue && SelectedMessages.Contains(message.SequenceNumber.Value);
                var isNavigated = index == MessageListState.NavigatedIndex;

                <div class="list-group-item message-item @(isSelected ? "selected" : "") @(isNavigated ? "navigated-active" : "")"
                     id="@(isNavigated ? "navigated-msg" : null)"
                     @onclick="() => OnMessageClick(message)">
                    <div class="d-flex align-items-center">
                        <div class="message-checkbox-wrapper" @onclick:stopPropagation="true">
                            <input class="form-check-input message-checkbox" type="checkbox" 
                                   checked="@(message.SequenceNumber.HasValue && SelectedMessages.Contains(message.SequenceNumber.Value))"
                                   @onchange="() => ToggleMessage(message.SequenceNumber)">
                        </div>
                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div class="message-property-tags flex-grow-1" style="min-width: 0;">
                                    @foreach (var col in AlwaysOnProperties.Concat(_activeColumns).Distinct())
                                    {
                                        var val = GetPropertyValue(message, col);
                                        <span class="message-property-tag" title="@col: @(val ?? "(not set)")">
                                            <span class="property-tag-key">@col</span>
                                            <span class="property-tag-value @(val == null ? "text-muted" : "")">@(val ?? "—")</span>
                                        </span>
                                    }
                                    @if (IsScheduledMessage(message))
                                    {
                                        <span class="badge bg-info align-self-center" title="Scheduled for @FormatScheduledTime(message.ScheduledEnqueueTime!.Value)">
                                            <i class="bi bi-clock"></i> Scheduled
                                        </span>
                                    }
                                </div>
                                <small class="text-muted flex-shrink-0 ms-2" style="white-space: nowrap;">
                                    @if (IsScheduledMessage(message))
                                    {
                                        <span class="text-info" title="Scheduled delivery time">
                                            <i class="bi bi-clock-history"></i> @FormatScheduledTime(message.ScheduledEnqueueTime!.Value)
                                        </span>
                                    }
                                    else
                                    {
                                        @message.EnqueuedTime?.ToString("g")
                                    }
                                </small>
                            </div>
                            <div class="message-preview-container"
                                 onmouseenter="previewTooltip.show(this, event.clientX, event.clientY)"
                                 onmouseleave="previewTooltip.hide(this)">
                                <p class="mb-1 text-truncate message-preview-line">
                                    <small>@GetMessagePreview(message)</small>
                                </p>
                                <div class="message-preview-tooltip"
                                     onmouseenter="previewTooltip.enter(this)"
                                     onmouseleave="previewTooltip.hide(this.closest('.message-preview-container'))"
                                     @onclick:stopPropagation="true"
                                     @onmousedown:stopPropagation="true">@GetFullMessageBody(message)</div>
                            </div>
                            @if (message.DeliveryCount > 0)
                            {
                                <small class="text-warning">Delivery Count: @message.DeliveryCount</small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No messages found.
        </div>
    }
</div>

@code {
    [Parameter] public List<ServiceBusMessage> Messages { get; set; } = new();
    [Parameter] public bool IsDLQ { get; set; }
    [Parameter] public bool IsProcessing { get; set; }
    [Parameter] public bool RequiresSession { get; set; }
    [Parameter] public string? ColumnPreferenceKey { get; set; }
    [Parameter] public EventCallback<ServiceBusMessage> OnMessageSelected { get; set; }
    [Parameter] public EventCallback<List<long>> OnDeleteMessages { get; set; }
    [Parameter] public EventCallback<List<long>> OnResubmitMessages { get; set; }
    [Parameter] public EventCallback<List<long>> OnMoveToDLQMessages { get; set; }
    [Parameter] public EventCallback<string> OnScheduledMessageWarning { get; set; }
    [Parameter] public EventCallback OnClearMessages { get; set; }
    [Parameter] public EventCallback<List<long>> OnDownloadSelected { get; set; }
    [Parameter] public EventCallback OnDownloadLoaded { get; set; }
    [Parameter] public EventCallback OnDownloadEntireEntity { get; set; }

    // Always shown, locked in the dropdown (can't be unchecked)
    private static readonly IReadOnlyList<string> AlwaysOnBase = new[] { "SequenceNumber" };
    private static readonly HashSet<string> AlwaysShownDlqProps = new() { "DeadLetterReason" };

    // AlwaysOnProperties includes DLQ props when on a DLQ
    private IEnumerable<string> AlwaysOnProperties =>
        IsDLQ ? AlwaysOnBase.Concat(AlwaysShownDlqProps) : AlwaysOnBase;

    // _activeColumns = user-chosen custom app properties (stored in prefs)
    private List<string> _activeColumns = new();
    private HashSet<string> _discoveredAppProperties = new();
    private bool _showColumnDropdown = false;
    private string? _lastColumnPreferenceKey;

    private string SearchTerm
    {
        get => MessageListState.SearchTerm;
        set
        {
            if (MessageListState.SearchTerm != value)
            {
                MessageListState.SearchTerm = value;
                MessageListState.NavigatedIndex = -1; // Reset navigation on search
                MessageListState.NotifyUpdate();
            }
        }
    }

    private List<ServiceBusMessage> DisplayedMessages => MessageListState.FilteredMessages;

    protected override async Task OnParametersSetAsync()
    {
        // Reset active columns when entity changes
        if (ColumnPreferenceKey != _lastColumnPreferenceKey)
        {
            _lastColumnPreferenceKey = ColumnPreferenceKey;
            _discoveredAppProperties = new();
            _showColumnDropdown = false;

            _activeColumns = new List<string>();
            if (!string.IsNullOrEmpty(ColumnPreferenceKey))
            {
                var prefs = await PreferencesService.LoadPreferencesAsync();
                if (prefs.EntityColumnPreferences.TryGetValue(ColumnPreferenceKey, out var saved))
                    _activeColumns = saved
                        .Where(k => !AlwaysOnBase.Contains(k) && !AlwaysShownDlqProps.Contains(k))
                        .ToList();
            }
        }

        // Discover application property keys from loaded messages.
        // MessageId and DeadLetterErrorDescription are direct message fields, not in ApplicationProperties,
        // so inject them explicitly so they appear as selectable options.
        var props = new HashSet<string> { "MessageId" };
        if (IsDLQ) props.Add("DeadLetterErrorDescription");
        foreach (var msg in Messages)
        {
            if (msg.ApplicationProperties != null)
                foreach (var k in msg.ApplicationProperties.Keys) props.Add(k);
            if (msg.Properties != null)
                foreach (var k in msg.Properties.Keys) props.Add(k);
        }
        _discoveredAppProperties = props;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (MessageListState.NavigatedIndex != -1)
        {
            await JSRuntime.InvokeVoidAsync("scrollNavigatedIntoView");
        }
    }

    private HashSet<long> SelectedMessages { get; set; } = new();
    private bool allSelected = false;

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        allSelected = (bool)(e.Value ?? false);
        
        if (allSelected)
        {
            SelectedMessages = Messages.Where(m => m.SequenceNumber.HasValue).Select(m => m.SequenceNumber!.Value).ToHashSet();
        }
        else
        {
            SelectedMessages.Clear();
        }
    }

    private void ToggleMessage(long? sequenceNumber)
    {
        if (!sequenceNumber.HasValue) return;
        
        var seqNum = sequenceNumber.Value;
        if (SelectedMessages.Contains(seqNum))
        {
            SelectedMessages.Remove(seqNum);
        }
        else
        {
            SelectedMessages.Add(seqNum);
        }
        
        allSelected = SelectedMessages.Count == Messages.Count;
    }

    private async Task OnMessageClick(ServiceBusMessage message)
    {
        await OnMessageSelected.InvokeAsync(message);
    }

    private async Task OnDeleteSelected()
    {
        if (!SelectedMessages.Any()) return;
        
        await OnDeleteMessages.InvokeAsync(SelectedMessages.ToList());
    }

    private async Task OnResubmitSelected()
    {
        if (SelectedMessages.Any())
        {
            await OnResubmitMessages.InvokeAsync(SelectedMessages.ToList());
        }
    }

    private async Task OnMoveToDLQSelected()
    {
        if (!SelectedMessages.Any()) return;
        
        // Filter out scheduled messages - they cannot be moved to DLQ
        var (regularMessages, scheduledCount) = FilterOutScheduledMessages(SelectedMessages);
        
        if (scheduledCount > 0)
        {
            await OnScheduledMessageWarning.InvokeAsync($"{scheduledCount} scheduled message(s) were excluded. Scheduled messages cannot be moved to DLQ.");
        }
        
        if (regularMessages.Any())
        {
            await OnMoveToDLQMessages.InvokeAsync(regularMessages);
        }
    }

    private (List<long> regularMessages, int scheduledCount) FilterOutScheduledMessages(HashSet<long> sequenceNumbers)
    {
        var regularMessages = new List<long>();
        var scheduledCount = 0;
        
        foreach (var seqNum in sequenceNumbers)
        {
            var message = Messages.FirstOrDefault(m => m.SequenceNumber == seqNum);
            if (message != null && IsScheduledMessage(message))
            {
                scheduledCount++;
            }
            else
            {
                regularMessages.Add(seqNum);
            }
        }
        
        return (regularMessages, scheduledCount);
    }

    private void ToggleColumnDropdown()
    {
        _showColumnDropdown = !_showColumnDropdown;
    }

    private async Task ToggleColumn(string key)
    {
        if (_activeColumns.Contains(key))
            _activeColumns.Remove(key);
        else
            _activeColumns.Add(key);

        if (!string.IsNullOrEmpty(ColumnPreferenceKey))
        {
            var prefs = await PreferencesService.LoadPreferencesAsync();
            prefs.EntityColumnPreferences[ColumnPreferenceKey] = new List<string>(_activeColumns);
            await PreferencesService.SavePreferencesAsync(prefs);
        }
    }

    private static string? GetPropertyValue(ServiceBusMessage message, string key) => key switch
    {
        "SequenceNumber" => message.SequenceNumber?.ToString(),
        "MessageId" => message.MessageId,
        "DeadLetterReason" => GetAppProperty(message, key),
        "DeadLetterErrorDescription" => GetAppProperty(message, key),
        _ => GetAppProperty(message, key),
    };

    private static string? GetAppProperty(ServiceBusMessage message, string key)
    {
        if (message.ApplicationProperties != null && message.ApplicationProperties.TryGetValue(key, out var v1))
            return v1?.ToString();
        if (message.Properties != null && message.Properties.TryGetValue(key, out var v2))
            return v2?.ToString();
        return null;
    }

    private MarkupString GetMessagePreview(ServiceBusMessage message)
    {
        var bodyStr = message.Body?.ToString() ?? "";
        
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            // Just return encoded body, let CSS truncate
            return (MarkupString)System.Net.WebUtility.HtmlEncode(bodyStr);
        }

        // Contextual highlight
        var idx = bodyStr.IndexOf(SearchTerm, StringComparison.OrdinalIgnoreCase);
        if (idx == -1) return (MarkupString)System.Net.WebUtility.HtmlEncode(bodyStr); // fallback

        const int ContextPadding = 50;
        int start = Math.Max(0, idx - ContextPadding);
        int length = Math.Min(bodyStr.Length - start, idx - start + SearchTerm.Length + ContextPadding);
        
        string substring = bodyStr.Substring(start, length);
        string encodedSubstring = System.Net.WebUtility.HtmlEncode(substring);
        string encodedTerm = System.Net.WebUtility.HtmlEncode(SearchTerm);
        
        string highlighted = Regex.Replace(encodedSubstring, Regex.Escape(encodedTerm), m => $"<mark>{m.Value}</mark>", RegexOptions.IgnoreCase);

        if (start > 0) highlighted = "..." + highlighted;
        if (start + length < bodyStr.Length) highlighted = highlighted + "...";
        
        return (MarkupString)highlighted;
    }

    private string GetFullMessageBody(ServiceBusMessage message)
    {
        return message.Body?.ToString() ?? "(empty)";
    }

    // Public method to clear selection (can be called from parent)
    public void ClearSelection()
    {
        SelectedMessages.Clear();
        allSelected = false;
        StateHasChanged();
    }

    private static bool IsScheduledMessage(ServiceBusMessage message) => MessageHelpers.IsScheduledMessage(message);

    private static string FormatScheduledTime(long unixMs)
    {
        var scheduledTime = DateTimeOffset.FromUnixTimeMilliseconds(unixMs);
        var localTime = scheduledTime.LocalDateTime;
        var now = DateTime.Now;
        
        // If it's today, just show time
        if (localTime.Date == now.Date)
            return $"Today {localTime:HH:mm}";
        
        // If it's tomorrow, show "Tomorrow HH:mm"
        if (localTime.Date == now.Date.AddDays(1))
            return $"Tomorrow {localTime:HH:mm}";
        
        // Otherwise show full date/time
        return localTime.ToString("g");
    }

    private async Task OnClearMessagesClick()
    {
        await OnClearMessages.InvokeAsync();
    }

    private bool showDownloadDropdown = false;

    private void ToggleDownloadDropdown()
    {
        showDownloadDropdown = !showDownloadDropdown;
    }

    private async Task DownloadSelected()
    {
        await OnDownloadSelected.InvokeAsync(SelectedMessages.ToList());
    }

    private async Task DownloadLoaded()
    {
        showDownloadDropdown = false;
        await OnDownloadLoaded.InvokeAsync();
    }

    private async Task DownloadEntireEntity()
    {
        showDownloadDropdown = false;
        await OnDownloadEntireEntity.InvokeAsync();
    }
}
